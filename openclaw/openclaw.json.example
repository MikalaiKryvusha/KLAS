            "contextWindow": 98304,
            "maxTokens": 8192,
            "input": ["text"],
            "compat": { "unsupportedToolSchemaKeywords": ["pattern"] }
          },
          {
            "id": "qwen3.6-35b-a3b-r",
            "name": "Qwen3.6-35B-A3B retry-alias (РЎвҖҡР С•РЎвҖҡ Р В¶Р Вө Р С‘Р Р…РЎРғРЎвҖҡР В°Р Р…РЎРғ llama-swap; fallback РІвҖһвҖ“1 = РЎРӮР ВөРЎвҖҡРЎРӮР В°Р в„– РЎвҖҡР С•Р в„– Р В¶Р Вө Р СҳР С•Р Т‘Р ВөР В»Р С‘ Р С—РЎРӮР С‘ 500 РЎРғР ВөРЎРӮР РҶР ВөРЎРӮР В°)",
            "contextWindow": 98304,
            "maxTokens": 8192,
            "input": ["text"],
            "compat": { "unsupportedToolSchemaKeywords": ["pattern"] }
          },
          {
            "id": "qwen3.5-35b",
            "name": "Qwen3.5-35B-A3B (Р ВұРЎвҖ№Р РҶРЎвӮ¬Р В°РЎРҸ Р С•РЎРғР Р…Р С•Р РҶР Р…Р В°РЎРҸ РІвҖ вҖҷ fallback Р Т‘Р С• Р С•Р ВұР С”Р В°РЎвҖҡР С”Р С‘ 3.6, Р С‘Р Р…РЎвҖҡ. 006 Q2; РЎвҖ Р ВөР С—Р С•РЎвҖЎР С”Р С‘ 5/6)",
            "contextWindow": 98304,
            "maxTokens": 8192,
            "input": ["text"],
            "compat": { "unsupportedToolSchemaKeywords": ["pattern"] }
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "klas/qwen3.6-35b-a3b",
        "fallbacks": ["klas/qwen3.6-35b-a3b-r", "klas/qwen3.5-35b"]
      },
      "skills": ["healthcheck", "skill-creator"]
    }
  },
  "tools": {
    "exec": {
      "security": "allowlist",
      "ask": "off"
    }
  },
  "messages": {
    "tts": {
      "enabled": true,
      "auto": "off",
      "provider": "tts-local-cli",
      "providers": {
        "tts-local-cli": {
          "command": "node",
          "args": ["F:\\KLAS\\tools\\voice-say.mjs", "{{Text}}", "--out", "{{OutputPath}}"],
          "outputFormat": "wav",
          "timeoutMs": 120000
        }
      }
    }
  },
  "gateway": {
    "mode": "local",
    "bind": "tailnet",
    "port": 18789,
    "auth": {
      "mode": "token",
      "token": "Р’РЎРўРҗР’Р¬_РЎРӣРЈР§РҗРҷРқР«Рҷ_РўРһРҡР•Рқ_64_HEX (СҖРөР°Р»СҢРҪСӢР№ вҖ” РІ caddy/PASSWORD.local.txt, РІРҪРө git)"
    },
    "controlUi": {
      "enabled": true
    }
  }
}
