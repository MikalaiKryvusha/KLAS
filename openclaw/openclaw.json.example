{
  "models": {
    "providers": {
      "klas": {
        "baseUrl": "http://127.0.0.1:8080/v1",
        "apiKey": "sk-local-klas",
        "api": "openai-completions",
        "models": [
          {
            "id": "qwen3.6-35b-a3b",
