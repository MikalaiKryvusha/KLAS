# Тяжёлые/генерируемые артефакты — в git не попадают (репозиторий для документов, конфигов, скриптов)
*.gguf
node_modules/
*.log
logs/

# Инфраструктура рядом с каркасом (идея 03: git = обёртка/фрейм; тяжёлое скачивает deploy).
# Версионируем только текстовые конфиги: профили запуска llamacpp\bat и Caddyfile.
/llamacpp/*
!/llamacpp/bat/
/LLMs/
/kiwixdb/
/homepage/*
!/homepage/config/
/homepage/config/*
!/homepage/config/*.yaml
/AnythingLLM/
# Open WebUI: runtime-данные (data/) вне git; версионируем только свои тулы (open-webui/tools/)
/open-webui/*
!/open-webui/tools/
# Caddyfile содержит хеш пароля — в git только шаблон Caddyfile.example (инцидент 2026-07-03)
/caddy/*
!/caddy/Caddyfile.example
/mcp/
/nssm/

# Исходники логотипа тяжёлые — в git только готовые (KLAS.jpg подключён в README)
/logo/KLAS.psd
/logo/KLAS_ORIGIN_2x.png

# ── KAIF — вспомогательный dev-фреймворк, 3rd-party (идея 07) ─────────────────
# KLAS и KAIF — ДВЕ НЕЗАВИСИМЫЕ СУЩНОСТИ. KAIF развёрнут здесь ЛОКАЛЬНО в помощь разработке KLAS,
# но в репозиторий KLAS не упаковывается (как любая 3rd-party библиотека — ссылаемся и разворачиваем
# локально, см. tools/deploy.mjs). Файлы KAIF физически остаются на диске, но вне git-трекинга.
/.kaif/
/.claude/
/.roo/
KAIF_FRAMEWORK.md
AGENT_GUIDE.md
PHILOSOPHY.md
BUG_FIXING_FRAMEWORK.md
AGENTS.md
CLAUDE.md
/tools/kaif.mjs
KAIF.md
kaif-unpack.mjs

# Ярлык запуска KLAS (генерируется tools/install-klas-shortcut.ps1; машинно-зависимые абс. пути)
/KLAS.lnk

# Состояние мастера-установщика (прогресс/ответы конкретной машины) — не версионируем (план 05)
/.deploy-state.json
# Личная карта ссылок + ключей владельца (реальный funnel-хост, логин, пароль, Bearer-ключ) —
# в git только шаблон LINKS.md. Документ ключей и его PDF-рендер НЕ версионируются.
/LINKS.local.*
# страховка: любые *.local.pdf и временные html рендерера — мимо git
*.local.pdf
*.tmp.html

# Мусор ОС/редакторов
Thumbs.db
Desktop.ini
.DS_Store
